# Supabase — find these in Supabase: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Required for user invites and admin user management (server-only, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Used for invite email redirects (local dev)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Finnhub market data (server-only, never expose to browser)
FINNHUB_API_KEY=your-finnhub-api-key

# Google Gemini (server-only, never expose to browser)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL_FLASH=gemini-2.5-flash
GEMINI_MODEL_PRO=gemini-2.5-pro

# If local Supabase calls fail with "TypeError: fetch failed" on Windows/corporate networks,
# use: npm run dev:insecure
# (dev-only workaround — not used in production on Vercel)

# Supabase Auth redirect URLs to add in the dashboard:
# http://localhost:3000/auth/confirm
# http://localhost:3000/auth/callback
# https://your-production-domain/auth/confirm
# https://your-production-domain/auth/callback
